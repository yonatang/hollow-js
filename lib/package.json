{
  "name": "@yonatang/hollow-js",
  "version": "0.1.1",
  "description": "JavaScript implementation of Netflix Hollow - an in-memory data model framework",
  "homepage": "https://github.com/yonatang/hollow-js",
  "type": "module",
  "main": "dist/hollow.js",
  "module": "dist/hollow.esm.js",
  "browser": "dist/hollow.umd.js",
  "types": "dist/hollow.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src/**/*.js",
    "pack:local": "npm run build && npm pack",
    "install:demo": "npm run pack:local && cd ../demo && npm install ../lib/yonatang-hollow-js-*.tgz"
  },
  "keywords": [
    "javascript",
    "browser",
    "library"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "rollup": "^4.9.6"
  }
}
