{
  "name": "@yonatang/hollow-js",
  "version": "0.1.2",
  "description": "JavaScript implementation of Netflix Hollow - an in-memory data model framework",
  "homepage": "https://github.com/yonatang/hollow-js",
  "type": "module",
  "main": "dist/hollow.js",
  "module": "dist/hollow.esm.js",
  "browser": "dist/hollow.umd.js",
  "types": "dist/hollow.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:types && rollup -c && npm run build:copy-types",
    "build:types": "tsc",
    "build:copy-types": "cp dist/index.d.ts dist/hollow.d.ts",
    "dev": "rollup -c -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src/**/*.js",
    "pack:local": "npm run build && npm pack",
    "install:demo": "npm run pack:local && cd ../demo && npm install ../lib/yonatang-hollow-js-*.tgz"
  },
  "keywords": [
    "javascript",
    "browser",
    "library"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "rollup": "^4.60.1",
    "typescript": "^5.7.2"
  }
}
